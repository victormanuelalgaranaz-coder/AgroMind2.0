// ═══════════════════════════════════════════════════════
//  AGROMIND · Edge Function "chat"  (Supabase + Groq)
//  Pegá este código en tu función "chat" y volvé a hacer deploy.
//  Requiere el secret GROQ_API_KEY configurado en Supabase.
// ═══════════════════════════════════════════════════════

const corsHeaders = {
  'Access-Control-Allow-Origin': '*',
  'Access-Control-Allow-Headers': 'authorization, x-client-info, apikey, content-type',
  'Access-Control-Allow-Methods': 'POST, OPTIONS',
}

Deno.serve(async (req) => {
  if (req.method === 'OPTIONS') {
    return new Response('ok', { headers: corsHeaders })
  }

  try {
    const body = await req.json()
    console.log("Datos recibidos del frontend:", JSON.stringify(body))

    const { message, cropList, weatherInfo, city } = body

    const groqApiKey = Deno.env.get('GROQ_API_KEY')
    console.log("¿GROQ_API_KEY existe?:", groqApiKey ? "SÍ" : "NO")

    if (!groqApiKey) {
      console.error("Error: GROQ_API_KEY no encontrada en Deno.env")
      return new Response(
        JSON.stringify({ error: 'La variable GROQ_API_KEY no está configurada.' }),
        { headers: { ...corsHeaders, 'Content-Type': 'application/json' }, status: 400 }
      )
    }

    // ─── PROMPT EXPERTO EN AGRICULTURA ───────────────────────────────
    const systemPrompt = `Eres AgroMind, un ingeniero agronomo experto con mas de 20 anos de experiencia trabajando en el campo de Santa Cruz de la Sierra, Bolivia. Conoces a fondo los cultivos de la region: soya, maiz, girasol, arroz, trigo, frijol, cana de azucar y algodon, ademas del clima tropical y los suelos del oriente boliviano.

CONTEXTO ACTUAL DEL AGRICULTOR:
- Ubicacion: ${city || 'Santa Cruz de la Sierra'}
- Clima ahora mismo: ${weatherInfo || 'sin datos'}
- Cultivos que tiene sembrados: ${cropList || 'ninguno registrado'}

TU FORMA DE RESPONDER:
- Hablas como un agronomo de campo experimentado: cercano, claro y practico, no como un libro de texto.
- Das consejos CONCRETOS y ACCIONABLES que el agricultor pueda aplicar hoy mismo.
- Respuestas BREVES: 3 o 4 frases como maximo. Nada de relleno.
- Usas lenguaje sencillo, facil de entender para cualquier productor.
- SIEMPRE tienes en cuenta el clima actual y los cultivos del agricultor para personalizar tu respuesta.
- Si la pregunta es sobre plagas, riego o siembra, considera la temperatura y humedad de arriba.
- Si te preguntan algo fuera de la agricultura, redirige amablemente hacia temas del campo.
- Respondes siempre en espanol.`

    console.log("Enviando peticion a Groq...")

    const response = await fetch('https://api.groq.com/openai/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${groqApiKey}`,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        model: 'llama-3.3-70b-versatile',  // modelo mas capaz; podes usar llama-3.1-8b-instant si queres mas velocidad
        messages: [
          { role: 'system', content: systemPrompt },
          { role: 'user', content: message }
        ],
        temperature: 0.6,
        max_tokens: 400,
      }),
    })

    console.log("Respuesta de la API de Groq - Status:", response.status)

    if (!response.ok) {
      const errorData = await response.text()
      console.error("Error detallado de Groq:", errorData)
      return new Response(
        JSON.stringify({ error: `Error de Groq API: ${errorData}` }),
        { headers: { ...corsHeaders, 'Content-Type': 'application/json' }, status: 400 }
      )
    }

    const groqData = await response.json()
    const reply = groqData.choices[0]?.message?.content || 'No recibi respuesta del modelo.'

    return new Response(
      JSON.stringify({ reply }),
      { headers: { ...corsHeaders, 'Content-Type': 'application/json' }, status: 200 }
    )

  } catch (error) {
    console.error("Error global atrapado en el catch:", error.message)
    return new Response(
      JSON.stringify({ error: error.message }),
      { headers: { ...corsHeaders, 'Content-Type': 'application/json' }, status: 500 }
    )
  }
})
