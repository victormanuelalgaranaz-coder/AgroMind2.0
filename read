const corsHeaders = {
  'Access-Control-Allow-Origin': '*',
  'Access-Control-Allow-Headers': 'authorization, x-client-info, apikey, content-type',
  'Access-Control-Allow-Methods': 'POST, OPTIONS',
}

Deno.serve(async (req) => {
  if (req.method === 'OPTIONS') {
    return new Response('ok', { headers: corsHeaders })
  }

  try {
    const body = await req.json()
    console.log("Datos recibidos del frontend:", JSON.stringify(body))

    const { message, cropList, weatherInfo, city } = body

    const groqApiKey = Deno.env.get('GROQ_API_KEY')
    console.log("¿GROQ_API_KEY existe?:", groqApiKey ? "SÍ" : "NO")

    if (!groqApiKey) {
      console.error("Error: GROQ_API_KEY no encontrada en Deno.env")
      return new Response(
        JSON.stringify({ error: 'La variable GROQ_API_KEY no está configurada.' }),
        { headers: { ...corsHeaders, 'Content-Type': 'application/json' }, status: 400 }
      )
    }

    const systemPrompt = `Eres el asistente inteligente de Agromind. Estás ayudando a un agricultor en la ciudad de ${city}. Clima: ${weatherInfo}. Cultivos: ${cropList}.`

    console.log("Enviando petición a Groq...");
    const response = await fetch('https://api.groq.com/openai/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${groqApiKey}`,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        model: 'llama-3.1-8b-instant',
        messages: [
          { role: 'system', content: systemPrompt },
          { role: 'user', content: message }
        ],
        temperature: 0.7,
      }),
    })

    console.log("Respuesta de la API de Groq - Status:", response.status)

    if (!response.ok) {
      const errorData = await response.text()
      console.error("Error detallado de Groq:", errorData)
      return new Response(
        JSON.stringify({ error: `Error de Groq API: ${errorData}` }),
        { headers: { ...corsHeaders, 'Content-Type': 'application/json' }, status: 400 }
      )
    }

    const groqData = await response.json()
    const reply = groqData.choices[0]?.message?.content || 'No recibí respuesta del modelo.'

    return new Response(
      JSON.stringify({ reply }),
      { headers: { ...corsHeaders, 'Content-Type': 'application/json' }, status: 200 }
    )

  } catch (error) {
    console.error("Error global atrapado en el catch:", error.message)
    return new Response(
      JSON.stringify({ error: error.message }),
      { headers: { ...corsHeaders, 'Content-Type': 'application/json' }, status: 500 }
    )
  }
})


