<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>AgroMind · Pitch</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Noto+Color+Emoji&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}

:root{
  --bg-top:#F6F2E8;
  --bg-bottom:#EAE3D2;
  --card:#FFFFFF;
  --text-dark:#2A2A28;
  --text-light:#5E5C57;
  --border:#E2DCCD;
  /* Acentos tomados del logo */
  --ocre:#C3833B;
  --ocre-dark:#A66A28;
  --wheat:#E0A93F;
  --wheat-light:#F2CA6B;
  --green:#3E9A52;
  --green-dark:#1F6E3A;
  --teal:#2E8C7A;
  --green-soft:#EAF4EC;
  --ocre-soft:#F7ECDA;
  --red:#D8654F;
}

html,body{height:100%}
body{
  font-family:'Plus Jakarta Sans','Noto Color Emoji',system-ui,sans-serif;
  background:linear-gradient(160deg,var(--bg-top) 0%,var(--bg-bottom) 100%);
  color:var(--text-dark);
  display:flex;align-items:center;justify-content:center;
  min-height:100vh;overflow:hidden;
}

.stage{
  position:relative;
  width:min(94vw,1180px);
  aspect-ratio:16/9;
  background:linear-gradient(160deg,var(--bg-top) 0%,var(--bg-bottom) 100%);
  border:1px solid var(--border);
  border-radius:26px;
  overflow:hidden;
  box-shadow:0 30px 80px rgba(42,42,40,0.18);
}
.stage::before{
  content:'';position:absolute;inset:0;pointer-events:none;
  background:
    radial-gradient(420px 280px at 88% -8%, rgba(195,131,59,0.12), transparent 60%),
    radial-gradient(360px 240px at -6% 110%, rgba(62,154,82,0.10), transparent 60%);
}

/* espigas/hojas flotantes */
.leaf{position:absolute;font-size:24px;opacity:0;animation:floatLeaf linear infinite;z-index:1}
@keyframes floatLeaf{
  0%{opacity:0;transform:translateY(20px) rotate(0)}
  10%{opacity:.45}90%{opacity:.45}
  100%{opacity:0;transform:translateY(-120px) rotate(36deg)}
}

.scene{
  position:absolute;inset:0;z-index:2;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  text-align:center;padding:6%;
  opacity:0;visibility:hidden;transition:opacity .6s ease,visibility .6s;
}
.scene.active{opacity:1;visibility:visible}
.scene.active .up{animation:up .7s cubic-bezier(.2,.7,.2,1) both}
.scene.active .up2{animation:up .7s cubic-bezier(.2,.7,.2,1) .12s both}
.scene.active .up3{animation:up .7s cubic-bezier(.2,.7,.2,1) .24s both}
.scene.active .up4{animation:up .7s cubic-bezier(.2,.7,.2,1) .36s both}
.scene.active .pop{animation:pop .7s cubic-bezier(.34,1.56,.64,1) .05s both}
@keyframes up{from{opacity:0;transform:translateY(26px)}to{opacity:1;transform:translateY(0)}}
@keyframes pop{from{opacity:0;transform:scale(.55)}to{opacity:1;transform:scale(1)}}

.kicker{
  display:inline-block;font-size:clamp(11px,1.4vw,15px);font-weight:700;
  letter-spacing:.18em;text-transform:uppercase;color:var(--green-dark);
  background:var(--green-soft);border:1px solid var(--border);
  padding:7px 16px;border-radius:999px;margin-bottom:22px;
}
.kicker.ocre{color:var(--ocre-dark);background:var(--ocre-soft)}
h1{font-size:clamp(34px,6vw,72px);font-weight:800;letter-spacing:-1.5px;line-height:1.04}
h1 .g{color:var(--green-dark)}
h1 .o{color:var(--ocre-dark)}
h2{font-size:clamp(24px,4.2vw,46px);font-weight:800;letter-spacing:-.8px;line-height:1.12;max-width:16ch}
.lead{font-size:clamp(15px,2.1vw,22px);color:var(--text-light);font-weight:500;margin-top:18px;max-width:27ch;line-height:1.5}

/* ── LOGO (recreado del PNG, vectorial) ── */
.logo-mark{width:clamp(110px,15vw,168px);height:auto;margin-bottom:24px}
.logo-mark svg{width:100%;height:auto;display:block;filter:drop-shadow(0 14px 26px rgba(166,106,40,0.30))}
.logo-sway{transform-origin:50% 100%;animation:sway 4.5s ease-in-out infinite}
@keyframes sway{0%,100%{transform:rotate(-2deg)}50%{transform:rotate(2deg)}}

.card{background:var(--card);border:1px solid var(--border);border-radius:20px;box-shadow:0 16px 40px rgba(42,42,40,0.10);padding:26px 30px}

.weather-card{display:flex;align-items:center;gap:28px;text-align:left;min-width:min(86%,560px)}
.wc-emoji{font-size:clamp(50px,8vw,84px);line-height:1}
.wc-temp{font-size:clamp(40px,7vw,72px);font-weight:800;letter-spacing:-2px;color:var(--green-dark);line-height:1}
.wc-row{display:flex;gap:24px;margin-top:10px}
.wc-pill{display:flex;flex-direction:column}
.wc-val{font-size:clamp(18px,2.6vw,26px);font-weight:700;color:var(--text-dark)}
.wc-lbl{font-size:13px;color:var(--text-light);font-weight:600;text-transform:uppercase;letter-spacing:.05em}

.pest-wrap{display:flex;align-items:center;gap:34px;flex-wrap:wrap;justify-content:center}
.shield{
  width:clamp(90px,13vw,140px);height:clamp(90px,13vw,140px);
  display:flex;align-items:center;justify-content:center;font-size:clamp(44px,7vw,72px);
  background:var(--green-soft);border:2px solid var(--border);border-radius:28px;
  box-shadow:0 14px 34px rgba(62,154,82,0.18);animation:pulseShield 2.4s ease-in-out infinite;
}
@keyframes pulseShield{0%,100%{box-shadow:0 14px 34px rgba(62,154,82,0.18)}50%{box-shadow:0 14px 50px rgba(62,154,82,0.40)}}
.bars{display:flex;flex-direction:column;gap:14px;min-width:min(70%,360px);text-align:left}
.bar-row{display:flex;flex-direction:column;gap:6px}
.bar-top{display:flex;justify-content:space-between;align-items:center;font-size:clamp(13px,1.8vw,16px);font-weight:600}
.bar-track{height:14px;background:#F0EBDD;border:1px solid var(--border);border-radius:999px;overflow:hidden}
.bar-fill{height:100%;width:0;border-radius:999px;transition:width 1.1s cubic-bezier(.2,.8,.2,1)}
.scene.active .bar-fill{width:var(--w)}
.bar-fill.lo{background:linear-gradient(90deg,#7FC78D,var(--green))}
.bar-fill.mid{background:linear-gradient(90deg,#E9C06B,var(--wheat))}
.bar-fill.hi{background:linear-gradient(90deg,#E89178,var(--red))}
.tag{font-size:12px;font-weight:700;padding:2px 10px;border-radius:999px}
.tag.lo{color:var(--green-dark);background:var(--green-soft)}
.tag.mid{color:var(--ocre-dark);background:var(--ocre-soft)}
.tag.hi{color:#fff;background:var(--red)}

.chat{display:flex;flex-direction:column;gap:12px;min-width:min(82%,520px);text-align:left}
.msg{padding:13px 18px;border-radius:16px;font-size:clamp(14px,2vw,18px);font-weight:500;max-width:82%;opacity:0}
.msg.u{align-self:flex-end;background:linear-gradient(135deg,var(--green),var(--green-dark));color:#fff;border-bottom-right-radius:5px}
.msg.b{align-self:flex-start;background:var(--card);border:1px solid var(--border);color:var(--text-dark);border-bottom-left-radius:5px;box-shadow:0 8px 20px rgba(42,42,40,0.07)}
.scene.active .msg.m1{animation:up .5s ease .2s both}
.scene.active .msg.m2{animation:up .5s ease .9s both}
.scene.active .msg.m3{animation:up .5s ease 1.7s both}

.cta-btn{
  margin-top:30px;display:inline-flex;align-items:center;gap:12px;
  background:linear-gradient(135deg,var(--green),var(--green-dark));color:#fff;
  font-size:clamp(16px,2.4vw,22px);font-weight:700;padding:16px 38px;border-radius:999px;
  box-shadow:0 14px 34px rgba(62,154,82,0.4);animation:ctaPulse 2.2s ease-in-out infinite;
}
@keyframes ctaPulse{0%,100%{box-shadow:0 14px 34px rgba(62,154,82,0.40)}50%{box-shadow:0 14px 48px rgba(62,154,82,0.65);transform:translateY(-2px)}}

.logo-mini{width:clamp(60px,8vw,88px);height:auto;margin-bottom:18px}
.logo-mini svg{width:100%;height:auto;display:block}

.progress{position:absolute;bottom:0;left:0;right:0;height:5px;background:rgba(226,220,205,0.6);z-index:5}
.progress-bar{height:100%;width:0;background:linear-gradient(90deg,var(--wheat),var(--ocre-dark))}
.dots{position:absolute;bottom:18px;left:50%;transform:translateX(-50%);display:flex;gap:9px;z-index:5}
.dot{width:8px;height:8px;border-radius:50%;background:var(--border);transition:all .3s}
.dot.on{background:var(--ocre-dark);width:26px;border-radius:999px}

.brand-corner{position:absolute;top:18px;left:22px;display:flex;align-items:center;gap:10px;z-index:5;font-weight:800;color:var(--text-dark);font-size:clamp(15px,2vw,19px);letter-spacing:-.4px}
.brand-corner svg{width:30px;height:auto;display:block}
</style>
</head>
<body>

<div class="stage" id="stage">

  <div class="leaf" style="left:12%;animation-duration:9s">🌾</div>
  <div class="leaf" style="left:34%;animation-duration:11s;animation-delay:2s">🍃</div>
  <div class="leaf" style="left:66%;animation-duration:10s;animation-delay:1s">🌱</div>
  <div class="leaf" style="left:84%;animation-duration:12s;animation-delay:3s">🌾</div>

  <!-- marca esquina (logo mini) -->
  <div class="brand-corner">
    <svg viewBox="0 0 100 116" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="wheatG2" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0" stop-color="#F2CA6B"/><stop offset="1" stop-color="#C3833B"/>
        </linearGradient>
        <linearGradient id="leafG2" x1="0" y1="1" x2="1" y2="0">
          <stop offset="0" stop-color="#1F6E3A"/><stop offset=".5" stop-color="#2E8C7A"/><stop offset="1" stop-color="#3E9A52"/>
        </linearGradient>
      </defs>
      <use href="#logoArt"/>
    </svg>
  </div>

  <!-- DEFINICIÓN DEL LOGO (reutilizable) -->
  <svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <defs>
      <linearGradient id="wheatG" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="#F2CA6B"/><stop offset=".55" stop-color="#E0A93F"/><stop offset="1" stop-color="#B5752E"/>
      </linearGradient>
      <linearGradient id="leafG" x1="0" y1="1" x2="1" y2="0">
        <stop offset="0" stop-color="#1F6E3A"/><stop offset=".5" stop-color="#2E8C7A"/><stop offset="1" stop-color="#46A85B"/>
      </linearGradient>
      <g id="logoArt">
        <!-- tallos -->
        <rect x="46.5" y="40" width="3.4" height="64" rx="1.7" fill="url(#leafG)"/>
        <rect x="62.5" y="52" width="3.4" height="52" rx="1.7" fill="url(#leafG)"/>
        <!-- hojas base -->
        <path d="M48 92 C40 86 33 86 27 90 C34 96 42 97 48 94 Z" fill="url(#leafG)"/>
        <path d="M48 100 C42 96 35 97 30 101 C36 106 44 106 48 103 Z" fill="url(#leafG)" opacity=".9"/>
        <path d="M64 96 C70 90 77 90 83 94 C77 100 69 101 64 98 Z" fill="url(#leafG)"/>
        <path d="M64 104 C69 100 76 101 81 105 C75 110 68 109 64 106 Z" fill="url(#leafG)" opacity=".9"/>
        <!-- espiga 1 (forma de E/F con granos) -->
        <g fill="url(#wheatG)">
          <path d="M48 36 C44 30 44 24 48 18 C52 24 52 30 48 36 Z"/>
          <path d="M48 44 C42 40 38 41 35 45 C40 49 46 48 48 45 Z"/>
          <path d="M48 44 C54 40 58 41 61 45 C56 49 50 48 48 45 Z"/>
          <path d="M48 54 C42 50 38 51 35 55 C40 59 46 58 48 55 Z"/>
          <path d="M48 54 C54 50 58 51 61 55 C56 59 50 58 48 55 Z"/>
          <path d="M48 64 C43 61 39 62 36 65 C40 69 46 67 48 65 Z"/>
        </g>
        <!-- espiga 2 -->
        <g fill="url(#wheatG)">
          <path d="M64 48 C60 42 60 36 64 30 C68 36 68 42 64 48 Z"/>
          <path d="M64 56 C58 52 54 53 51 57 C56 61 62 60 64 57 Z"/>
          <path d="M64 56 C70 52 74 53 77 57 C72 61 66 60 64 57 Z"/>
          <path d="M64 66 C58 62 54 63 51 67 C56 71 62 70 64 67 Z"/>
          <path d="M64 66 C70 62 74 63 77 67 C72 71 66 70 64 67 Z"/>
          <path d="M64 76 C59 73 55 74 52 77 C56 81 62 79 64 77 Z"/>
        </g>
      </g>
    </defs>
  </svg>

  <!-- ESCENA 1 · MARCA -->
  <section class="scene" data-dur="3800">
    <div class="logo-mark pop">
      <svg viewBox="0 0 100 116" class="logo-sway" xmlns="http://www.w3.org/2000/svg"><use href="#logoArt"/></svg>
    </div>
    <h1 class="up">Agro<span class="g">Mind</span></h1>
    <p class="lead up2">Agronomía impulsada por Inteligencia Artificial</p>
  </section>

  <!-- ESCENA 2 · PROBLEMA -->
  <section class="scene" data-dur="3800">
    <span class="kicker ocre up">El problema</span>
    <h2 class="up2">Cada año, las plagas arruinan cosechas enteras</h2>
    <p class="lead up3">Decidir a ciegas cuesta tiempo, dinero y alimento para todos.</p>
  </section>

  <!-- ESCENA 3 · CLIMA -->
  <section class="scene" data-dur="4000">
    <span class="kicker up">Clima en tiempo real</span>
    <div class="card weather-card pop">
      <div class="wc-emoji">⛅</div>
      <div>
        <div class="wc-temp">28°C</div>
        <div class="wc-row">
          <div class="wc-pill"><span class="wc-val">72%</span><span class="wc-lbl">Humedad</span></div>
          <div class="wc-pill"><span class="wc-val">3 mm</span><span class="wc-lbl">Lluvia</span></div>
          <div class="wc-pill"><span class="wc-val">12 km/h</span><span class="wc-lbl">Viento</span></div>
        </div>
      </div>
    </div>
    <p class="lead up3">El clima exacto de tu parcela, siempre actualizado.</p>
  </section>

  <!-- ESCENA 4 · PREVENCIÓN DE PLAGAS -->
  <section class="scene" data-dur="4600">
    <span class="kicker up">Prevención de plagas con IA</span>
    <div class="pest-wrap">
      <div class="shield pop">🛡️</div>
      <div class="bars">
        <div class="bar-row">
          <div class="bar-top"><span>🐛 Gusano cogollero</span><span class="tag hi">Alto</span></div>
          <div class="bar-track"><div class="bar-fill hi" style="--w:86%"></div></div>
        </div>
        <div class="bar-row">
          <div class="bar-top"><span>🍄 Roya / Hongos</span><span class="tag mid">Medio</span></div>
          <div class="bar-track"><div class="bar-fill mid" style="--w:58%"></div></div>
        </div>
        <div class="bar-row">
          <div class="bar-top"><span>🦗 Trips</span><span class="tag lo">Bajo</span></div>
          <div class="bar-track"><div class="bar-fill lo" style="--w:30%"></div></div>
        </div>
      </div>
    </div>
    <p class="lead up4" style="max-width:34ch">Te avisamos del riesgo <strong>antes</strong> de que el daño aparezca.</p>
  </section>

  <!-- ESCENA 5 · ASISTENTE IA -->
  <section class="scene" data-dur="4400">
    <span class="kicker up">Asistente agrónomo 24/7</span>
    <div class="chat">
      <div class="msg u m1">¿Qué hago si llueve mucho esta semana? 🌧️</div>
      <div class="msg b m2">Suspendé el riego y revisá el drenaje. Con esa humedad, vigilá hongos en las hojas bajas. 🌱</div>
      <div class="msg u m3">¡Gracias! Justo lo que necesitaba 👨‍🌾</div>
    </div>
  </section>

  <!-- ESCENA 6 · CIERRE -->
  <section class="scene" data-dur="4200">
    <div class="logo-mini pop">
      <svg viewBox="0 0 100 116" xmlns="http://www.w3.org/2000/svg"><use href="#logoArt"/></svg>
    </div>
    <span class="kicker up">Tu campo, más inteligente</span>
    <h1 class="up2">Cultiva con <span class="g">inteligencia</span></h1>
    <div class="cta-btn up3">Probá AgroMind →</div>
  </section>

  <div class="dots" id="dots"></div>
  <div class="progress"><div class="progress-bar" id="progressBar"></div></div>
</div>

<script>
(function(){
  const scenes = Array.from(document.querySelectorAll('.scene'));
  const dotsWrap = document.getElementById('dots');
  const progressBar = document.getElementById('progressBar');
  let idx = 0, timer = null, rafId = null;

  scenes.forEach((_, i) => {
    const d = document.createElement('div');
    d.className = 'dot' + (i === 0 ? ' on' : '');
    dotsWrap.appendChild(d);
  });
  const dots = Array.from(dotsWrap.children);

  function animateProgress(duration){
    const start = performance.now();
    cancelAnimationFrame(rafId);
    function frame(now){
      const pct = Math.min(1, (now - start) / duration);
      progressBar.style.width = (pct * 100) + '%';
      if (pct < 1) rafId = requestAnimationFrame(frame);
    }
    rafId = requestAnimationFrame(frame);
  }

  function show(i){
    scenes.forEach((s, k) => s.classList.toggle('active', k === i));
    dots.forEach((d, k) => d.classList.toggle('on', k === i));
    const dur = parseInt(scenes[i].dataset.dur, 10) || 4000;
    animateProgress(dur);
    clearTimeout(timer);
    timer = setTimeout(() => { idx = (idx + 1) % scenes.length; show(idx); }, dur);
  }

  show(0);

  document.addEventListener('visibilitychange', () => {
    if (document.hidden) { clearTimeout(timer); cancelAnimationFrame(rafId); }
    else { show(idx); }
  });
  document.getElementById('stage').addEventListener('click', () => {
    idx = (idx + 1) % scenes.length; show(idx);
  });
})();
</script>
</body>
</html>
